{
  "name": "@vaagatech/snapline-messaging-adapters",
  "version": "0.2.3",
  "description": "Messaging queue adapters for Snapline — in-memory, Kafka, and custom publishers",
  "author": "VaagaTech (https://www.vaagatech.com)",
  "license": "MIT",
  "homepage": "https://vaagatech.github.io/snapline/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaagatech/snapline.git",
    "directory": "packages/messaging-adapters"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vaagatech/snapline-engine": "^0.2.3"
  },
  "peerDependencies": {
    "kafkajs": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "kafkajs": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
