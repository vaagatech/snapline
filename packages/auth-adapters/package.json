{
  "name": "@vaagatech/snapline-auth-adapters",
  "version": "0.2.0",
  "description": "Pluggable authentication adapters for OAuth2, OpenID Connect, and Basic Auth in test automation",
  "author": "VaagaTech (https://www.vaagatech.com)",
  "license": "MIT",
  "homepage": "https://www.vaagatech.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaagatech/snapline.git",
    "directory": "packages/auth-adapters"
  },
  "bugs": {
    "url": "https://github.com/vaagatech/snapline/issues"
  },
  "keywords": [
    "oauth2",
    "openid",
    "basic-auth",
    "authentication",
    "auth-adapter",
    "client-credentials",
    "test-automation",
    "vaagatech",
    "testing-framework"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
