{
  "name": "@vaagatech/snapline-engine",
  "version": "0.1.8",
  "description": "Deep data reconciliation engine for declarative snapshot testing — field stripping, transforms, and structural mapping",
  "author": "VaagaTech (https://www.vaagatech.com)",
  "license": "MIT",
  "homepage": "https://www.vaagatech.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vaagatech/snapline.git",
    "directory": "packages/snapline"
  },
  "bugs": {
    "url": "https://github.com/vaagatech/snapline/issues"
  },
  "keywords": [
    "reconcile",
    "reconciliation",
    "snapshot-testing",
    "declarative-testing",
    "json-fixtures",
    "data-mapping",
    "integration-testing",
    "vaagatech",
    "testing-framework"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "examples"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
