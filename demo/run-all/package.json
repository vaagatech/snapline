{
  "name": "@vaagatech/snapline-demo-run-all",
  "private": true,
  "version": "0.1.6",
  "description": "Runs all @vaagatech demo scenarios end-to-end",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "start": "node dist/run-all.js",
    "start:report:json": "REPORT_FORMAT=json REPORT_OUTPUT=./reports/test-report.json node dist/run-all.js",
    "start:report:html": "REPORT_FORMAT=html REPORT_OUTPUT=./reports/test-report.html node dist/run-all.js",
    "start:report:text": "REPORT_FORMAT=text REPORT_OUTPUT=./reports/test-report.txt node dist/run-all.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vaagatech/snapline-core": "0.1.6",
    "@vaagatech/snapline-demo-shared": "0.1.6",
    "@vaagatech/snapline-demo-scenario-api-vs-db-graphql": "0.1.6",
    "@vaagatech/snapline-demo-scenario-api-vs-db-rest": "0.1.6",
    "@vaagatech/snapline-demo-scenario-api-vs-db-soap": "0.1.6",
    "@vaagatech/snapline-demo-scenario-api-vs-file-graphql": "0.1.6",
    "@vaagatech/snapline-demo-scenario-api-vs-file-rest": "0.1.6",
    "@vaagatech/snapline-demo-scenario-api-vs-file-soap": "0.1.6",
    "@vaagatech/snapline-demo-scenario-db-comparison-transformations": "0.1.6",
    "@vaagatech/snapline-demo-scenario-db-vs-api-graphql": "0.1.6",
    "@vaagatech/snapline-demo-scenario-db-vs-api-rest": "0.1.6",
    "@vaagatech/snapline-demo-scenario-db-vs-api-soap": "0.1.6",
    "@vaagatech/snapline-demo-scenario-db-vs-db-sqlite": "0.1.6",
    "@vaagatech/snapline-demo-scenario-snapline-combined-options": "0.1.6",
    "@vaagatech/snapline-demo-scenario-snapline-data-mapping-function": "0.1.6",
    "@vaagatech/snapline-demo-scenario-snapline-ignore-fields": "0.1.6",
    "@vaagatech/snapline-demo-scenario-snapline-transformations": "0.1.6"
  }
}
